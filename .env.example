# ───────────────────────────────────────────────────────────
# SolSight — Environment Variables
# Copy this file to .env.local for local dev (`cp .env.example .env.local`)
# and set the same keys in your Vercel project settings for production.
# ───────────────────────────────────────────────────────────

# ── Database (Vercel Postgres / Supabase / any Postgres) ────
# Pooled connection string, used at runtime
DATABASE_URL="postgresql://user:password@host:5432/solsight?pgbouncer=true"
# Direct (non-pooled) connection string, used by Prisma Migrate
DIRECT_URL="postgresql://user:password@host:5432/solsight"

# ── NextAuth ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Discord OAuth app — https://discord.com/developers/applications
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# ── Privy (wallet connect + embedded wallets) ───────────────
# https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=""
PRIVY_APP_SECRET=""

# ── Anthropic (AI chart analysis + signal reasoning) ────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=""

# ── On-chain / market data ───────────────────────────────────
# https://birdeye.so — token prices, OHLCV, holder data
BIRDEYE_API_KEY=""
# https://docs.dexscreener.com — no key required, public rate-limited API
DEXSCREENER_BASE_URL="https://api.dexscreener.com"
# https://www.helius.dev — enhanced Solana RPC + webhooks for wallet tracking
HELIUS_API_KEY=""
NEXT_PUBLIC_SOLANA_RPC_URL="https://mainnet.helius-rpc.com/?api-key=your-helius-key"

# ── X (Twitter) API v2 — ticker mention tracking ─────────────
# https://developer.x.com
X_BEARER_TOKEN=""

# ── Background jobs (Inngest) ────────────────────────────────
# https://app.inngest.com
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ── Vercel Cron ───────────────────────────────────────────────
# Set to any random string; Vercel sends it as a header on cron invocations
CRON_SECRET=""

# ── App config ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="SolSight"
