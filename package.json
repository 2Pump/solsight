{
  "name": "solsight",
  "version": "0.1.0",
  "private": false,
  "description": "Open-source Solana memecoin signal intelligence — rug screening, bubble maps, AI chart reading, and wallet tracking in one beautiful dashboard.",
  "license": "MIT",
  "author": "SolSight Contributors",
  "homepage": "https://github.com/solsight/solsight",
  "scripts": {
    "dev": "next dev --turbo",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "inngest:dev": "inngest-cli dev -u http://localhost:3000/api/inngest",
    "postinstall": "prisma generate"
  },
  "dependencies": {
   "next": "15.5.21",
   "react": "18.3.1",
   "react-dom": "18.3.1",
    "typescript": "5.7.3",

    "@prisma/client": "6.2.1",
    "prisma": "6.2.1",

    "next-auth": "5.0.0-beta.25",
    "@auth/prisma-adapter": "2.7.4",

    "@privy-io/react-auth": "3.35.1",

    "@solana/web3.js": "1.98.0",
    "tweetnacl": "1.0.3",
    "bs58": "6.0.0",
    
    "@anthropic-ai/sdk": "0.33.1",

    "inngest": "3.27.4",

    "lightweight-charts": "4.2.2",

    "framer-motion": "11.15.0",
    "tailwind-merge": "2.6.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.469.0",

    "@radix-ui/react-avatar": "1.1.2",
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-dropdown-menu": "2.1.4",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-popover": "1.1.4",
    "@radix-ui/react-progress": "1.1.1",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-separator": "1.1.1",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-switch": "1.1.2",
    "@radix-ui/react-tabs": "1.1.2",
    "@radix-ui/react-toast": "1.2.4",
    "@radix-ui/react-tooltip": "1.1.6",

    "zod": "3.24.1",
    "zustand": "5.0.2",
    "date-fns": "4.1.0",
    "swr": "2.2.5"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.17",
    "tailwindcss-animate": "1.0.7",
    "eslint": "9.17.0",
    "eslint-config-next": "15.5.21",
    "prettier": "3.4.2",
    "prettier-plugin-tailwindcss": "0.6.9",
    "tsx": "4.19.2"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
